# ═══════════════════════════════════════════════════════
# 2026 世界杯预测系统 - 环境变量配置
# ═══════════════════════════════════════════════════════
#
# 复制此文件为 .env 然后填入你的 API Key：
#   cp .env.example .env
#
# ┌─────────────────────────────────────────────────┐
# │  数据源 1: API-Football (主数据源，强烈推荐)      │
# │  注册地址: https://dashboard.api-football.com     │
# │  或 RapidAPI: https://rapidapi.com/api-sports    │
# │  免费额度: 100次/天                               │
# │  包含: 球队/球员/赔率/赛程/伤停/交锋记录           │
# └─────────────────────────────────────────────────┘

# API-Football 密钥 (从 dashboard.api-football.com 获取)
API_FOOTBALL_KEY=

# API-Football 平台选择: auto / rapidapi / direct
# auto = 自动检测, direct = api-football.com 直连, rapidapi = 通过 RapidAPI
API_FOOTBALL_PLATFORM=auto

# ┌─────────────────────────────────────────────────┐
# │  数据源 2: football-data.org (备用，赔率补充)     │
# │  注册地址: https://www.football-data.org/client   │
# │  免费额度: 10次/分钟                               │
# │  包含: 赔率/赛程/积分榜                            │
# └─────────────────────────────────────────────────┘

# football-data.org API Token
FOOTBALL_DATA_KEY=

# ┌─────────────────────────────────────────────────┐
# │  可选: 代理设置 (国内用户可能需要)                  │
# └─────────────────────────────────────────────────┘

# HTTPS_PROXY=http://127.0.0.1:7890
# HTTP_PROXY=http://127.0.0.1:7890
